# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Prefer the anon/public key. Publishable key also works:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Monnify Sandbox ───────────────────────────────────────
MONNIFY_API_KEY=your_monnify_api_key
MONNIFY_SECRET_KEY=your_monnify_secret_key
MONNIFY_CONTRACT_CODE=your_contract_code
# Optional override (defaults to sandbox)
# MONNIFY_BASE_URL=https://sandbox.monnify.com/api/v1

# ── AI (OpenAI and/or Gemini) ─────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
# AI_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini

# ── Resend (API key delivery emails) ──────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Monapi <onboarding@resend.dev>

# ── App ───────────────────────────────────────────────────
# Force local file-backed demo store even if Supabase is set.
# On Vercel: leave unset (or false). If true, Live stays locked.
# MONAPI_DEMO_MODE=true
